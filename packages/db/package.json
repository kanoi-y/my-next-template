{
  "name": "@my-next-template/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:local": "turso dev --db-file local.db",
    "db:local:stop": "lsof -ti :8080 | xargs kill 2>/dev/null || true",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@libsql/client": "catalog:",
    "@my-next-template/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@my-next-template/config": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "typescript": "catalog:"
  }
}
