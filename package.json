{
  "name": "my-next-template",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @my-next-template/db db:push",
    "db:studio": "turbo -F @my-next-template/db db:studio",
    "db:generate": "turbo -F @my-next-template/db db:generate",
    "db:migrate": "turbo -F @my-next-template/db db:migrate",
    "db:local": "turbo -F @my-next-template/db db:local",
    "deploy": "turbo -F @my-next-template/infra deploy",
    "destroy": "turbo -F @my-next-template/infra destroy",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@my-next-template/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@cloudflare/workers-types": "catalog:",
    "@my-next-template/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.7.0"
  },
  "packageManager": "pnpm@11.1.0"
}
